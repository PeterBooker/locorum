<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4/v5 installer definition for Locorum.

  Built per-architecture by passing `wix build -arch x64|arm64`. The .exe
  source path and product version are passed in as preprocessor variables:

    wix build -arch x64 \
      -ext WixToolset.UI.wixext \
      -d Version=0.1.0.0 \
      -d SourceExe=build/dist/Locorum-windows-amd64.exe \
      -o build/dist/Locorum-0.1.0-windows-amd64.msi \
      packaging/windows/locorum.wxs

  UpgradeCode is immutable for the lifetime of the product line.
  Do NOT change it once a release ships, or upgrades will silently
  install a second copy alongside the old one.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="Locorum"
    Manufacturer="Peter Booker"
    Version="$(Version)"
    UpgradeCode="fb12c625-88a0-4ebb-aa53-fb70a86f77e1"
    Compressed="yes"
    Scope="perMachine">

    <SummaryInformation
      Description="Locorum — local WordPress dev environments"
      Manufacturer="Peter Booker" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Locorum is already installed." />

    <Media Id="1" Cabinet="locorum.cab" EmbedCab="yes" />

    <!-- Add/Remove Programs cosmetics. ARPPRODUCTICON pulls the icon from
         the installed exe (gogio embedded it). The URL fields are picked
         up by Windows Settings > Apps so the user has a way back to the
         project page for support / uninstall help.
         ARPNOMODIFY is set by WixUI_Minimal — don't redeclare it here. -->
    <Icon Id="LocorumIcon.exe" SourceFile="$(SourceExe)" />
    <Property Id="ARPPRODUCTICON" Value="LocorumIcon.exe" />
    <Property Id="ARPHELPLINK" Value="https://github.com/PeterBooker/locorum" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/PeterBooker/locorum" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Locorum">
        <Component Id="MainExe" Guid="08d57442-8d6b-4ba1-8e09-566549b67c7c">
          <File Id="LocorumExe" Source="$(SourceExe)" Name="Locorum.exe" KeyPath="yes" />
        </Component>
        <!-- Bundled mkcert. Installed next to Locorum.exe so the binary
             resolver picks it up without consulting $PATH or downloading.
             See SourceMkcert preprocessor variable in the Makefile MSI rule. -->
        <Component Id="MkcertExe" Guid="6dc4c1f9-1e1a-4b2d-9b3a-4e2c5d2b9a01">
          <File Id="MkcertExeFile" Source="$(SourceMkcert)" Name="mkcert.exe" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut Id="LocorumStartMenu"
                  Name="Locorum"
                  Description="Local WordPress dev environments"
                  Target="[INSTALLFOLDER]Locorum.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\PeterBooker\Locorum"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Per-user Desktop shortcut. Lives under HKCU rather than HKLM so
         each user on a shared machine gets their own shortcut on first
         launch via advertised-shortcut semantics. -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="9f7f4a34-2d1c-4e1f-9d62-2a3f3b7c6e2a">
        <Shortcut Id="LocorumDesktop"
                  Name="Locorum"
                  Description="Local WordPress dev environments"
                  Target="[INSTALLFOLDER]Locorum.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\PeterBooker\Locorum"
                       Name="desktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="Locorum" Level="1">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="MkcertExe" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- WixUI_Minimal: a single welcome dialog that displays the license
         and an Install button. Without this reference the MSI runs with
         no progress UI beyond the UAC prompt, which is jarring for end
         users. Requires `-ext WixToolset.UI.wixext` at build time. -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="packaging/windows/license.rtf" />
  </Package>
</Wix>
