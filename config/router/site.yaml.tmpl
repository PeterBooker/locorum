# locorum-generated — do not edit; regenerated each time the site state changes.
http:
  routers:
    locorum-{{ .Slug }}:
      rule: '{{ .Rule }}'
      entryPoints:
        - websecure
      service: locorum-{{ .Slug }}
      tls: {}
  services:
    locorum-{{ .Slug }}:
      loadBalancer:
        passHostHeader: true
        servers:
          - url: '{{ .Backend }}'
{{- if .CertFile }}
tls:
  certificates:
    - certFile: '{{ .CertFile }}'
      keyFile: '{{ .KeyFile }}'
{{- end }}
