user  nginx;
worker_processes  auto;
error_log  /var/log/nginx/error.log warn;
pid        /var/run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    log_format  main  '$remote_addr - $remote_user [$time_local] '
                      '"$request" $status $body_bytes_sent '
                      '"$http_referer" "$http_user_agent"';

    access_log  /var/log/nginx/access.log  main;

    include mime.types;

    server {
        listen              80;
        listen              [::]:80;
        server_name         {{ .Domain }};

        root                {{ NginxRoot . }};
        index               index.php index.html index.htm;

        # TLS terminates at the global router (Traefik). Tell PHP-FPM the
        # original request was HTTPS so WordPress builds correct site URLs.
        set $fcgi_https off;
        if ($http_x_forwarded_proto = "https") {
            set $fcgi_https on;
        }

        location = /favicon.ico {
            log_not_found off;
            access_log off;
        }

        location = /robots.txt {
            allow all;
            log_not_found off;
            access_log off;
        }

        location ~* \.(css|js|png|jpg|jpeg|gif|ico|woff|woff2|ttf|svg|eot)$ {
            try_files $uri =404;
            access_log off;
            log_not_found off;
        }

        location / {
            try_files $uri $uri/ /index.php?$args;
        }

        # WordPress Rewrites
        if (!-e $request_filename) {
            rewrite (/wp-.*)       /wp$1      last;
            rewrite (/.*\.php)$    /wp$1      last;
        }
{{- if eq .Multisite "subdirectory" }}

        # WordPress Multisite (Subdirectory) rewrites
        if (!-e $request_filename) {
            rewrite /wp-admin$ $scheme://$host$uri/ permanent;
            rewrite ^(/[^/]+)?(/wp-.*) $2 last;
            rewrite ^(/[^/]+)?(/.*\.php) $2 last;
        }
{{- end }}

        location ~ \.php$ {
            try_files $uri =404;
            include      fastcgi.conf;
            fastcgi_pass locorum-{{ .Slug }}-php:9000;
            include      fastcgi_params;
            fastcgi_param HTTPS                $fcgi_https;
            fastcgi_param HTTP_X_FORWARDED_PROTO $http_x_forwarded_proto;
            fastcgi_buffers            256 48k;
            fastcgi_buffer_size        48k;
            fastcgi_connect_timeout    60s;
            fastcgi_send_timeout       60s;
            fastcgi_read_timeout       60s;
            fastcgi_busy_buffers_size  256k;
            fastcgi_max_temp_file_size 0;
            reset_timedout_connection  on;
        }
    }
}
